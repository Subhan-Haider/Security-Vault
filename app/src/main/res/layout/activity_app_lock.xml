<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Fake System Crash UI (Stealth Layer) -->
    <LinearLayout
        android:id="@+id/llFakeCrash"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@android:drawable/stat_notify_error"
            app:tint="@color/on_surface_secondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="System UI isn't responding"
            android:textColor="@color/on_surface"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="An internal error occurred. Send a report to help fix the problem."
            android:textColor="@color/on_surface_secondary" />

        <Button
            android:id="@+id/btnOk"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Close app" />
    </LinearLayout>

    <!-- Hidden PIN Pad (Activated by long pressing the error icon) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvPinPad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:visibility="gone"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/card_stroke_color"
        app:cardBackgroundColor="@color/surface"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvPinDisplay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:letterSpacing="0.5"
                android:padding="16dp"
                android:text=""
                android:textColor="@color/primary"
                android:textSize="32sp"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:rowCount="4">

                <Button android:id="@+id/btn1" style="@style/Widget.Material3.Button.TextButton" android:text="1" android:textSize="24sp" android:textColor="@color/on_surface" android:layout_columnWeight="1" />
                <Button android:id="@+id/btn2" style="@style/Widget.Material3.Button.TextButton" android:text="2" android:textSize="24sp" android:textColor="@color/on_surface" android:layout_columnWeight="1" />
                <Button android:id="@+id/btn3" style="@style/Widget.Material3.Button.TextButton" android:text="3" android:textSize="24sp" android:textColor="@color/on_surface" android:layout_columnWeight="1" />
                
                <Button android:id="@+id/btn4" style="@style/Widget.Material3.Button.TextButton" android:text="4" android:textSize="24sp" android:textColor="@color/on_surface" android:layout_columnWeight="1" />
                <Button android:id="@+id/btn5" style="@style/Widget.Material3.Button.TextButton" android:text="5" android:textSize="24sp" android:textColor="@color/on_surface" android:layout_columnWeight="1" />
                <Button android:id="@+id/btn6" style="@style/Widget.Material3.Button.TextButton" android:text="6" android:textSize="24sp" android:textColor="@color/on_surface" android:layout_columnWeight="1" />
                
                <Button android:id="@+id/btn7" style="@style/Widget.Material3.Button.TextButton" android:text="7" android:textSize="24sp" android:textColor="@color/on_surface" android:layout_columnWeight="1" />
                <Button android:id="@+id/btn8" style="@style/Widget.Material3.Button.TextButton" android:text="8" android:textSize="24sp" android:textColor="@color/on_surface" android:layout_columnWeight="1" />
                <Button android:id="@+id/btn9" style="@style/Widget.Material3.Button.TextButton" android:text="9" android:textSize="24sp" android:textColor="@color/on_surface" android:layout_columnWeight="1" />
                
                <Button android:id="@+id/btnClear" style="@style/Widget.Material3.Button.TextButton" android:text="C" android:textColor="@color/accent_red" android:layout_columnWeight="1" />
                <Button android:id="@+id/btn0" style="@style/Widget.Material3.Button.TextButton" android:text="0" android:textSize="24sp" android:textColor="@color/on_surface" android:layout_columnWeight="1" />
                <Button android:id="@+id/btnCancel" style="@style/Widget.Material3.Button.TextButton" android:text="⤶" android:textColor="@color/on_surface" android:layout_columnWeight="1" />
            </GridLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Invisible trigger -->
    <View
        android:id="@+id/vUnlockTrigger"
        android:layout_width="64dp"
        android:layout_height="64dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="100dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
