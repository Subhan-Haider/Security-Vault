<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Display Area -->
    <LinearLayout
        android:id="@+id/displayContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="bottom|end"
        app:layout_constraintHeight_percent="0.35"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="CREATE MASTER PIN"
            android:textColor="@color/on_surface_secondary"
            android:textSize="20sp"
            android:maxLines="1"
            android:ellipsize="start" />

        <TextView
            android:id="@+id/tvDisplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="0"
            android:textColor="@color/on_surface"
            android:textSize="64sp"
            android:textStyle="bold"
            app:autoSizeMaxTextSize="72sp"
            app:autoSizeMinTextSize="24sp"
            app:autoSizeTextType="uniform" />
    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_color"
        app:layout_constraintTop_toBottomOf="@id/displayContainer" />

    <!-- Numerical Keypad using Constraint Grid -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/keypad"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Row 1 -->
        <Button style="@style/CalculatorButtonStyle.Action" android:id="@+id/btnClear" android:text="AC"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnPlusMinus" app:layout_constraintWidth_percent="0.22" />
        <Button style="@style/CalculatorButtonStyle.Action" android:id="@+id/btnPlusMinus" android:text="±"
            app:layout_constraintStart_toEndOf="@id/btnClear" app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnPercent" app:layout_constraintWidth_percent="0.22" />
        <Button style="@style/CalculatorButtonStyle.Action" android:id="@+id/btnPercent" android:text="%"
            app:layout_constraintStart_toEndOf="@id/btnPlusMinus" app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnDiv" app:layout_constraintWidth_percent="0.22" />
        <Button style="@style/CalculatorButtonStyle.Operator" android:id="@+id/btnDiv" android:text="÷"
            app:layout_constraintStart_toEndOf="@id/btnPercent" app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" app:layout_constraintWidth_percent="0.22" />

        <!-- Row 2 -->
        <Button style="@style/CalculatorButtonStyle" android:id="@+id/btn7" android:text="7"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/btnClear"
            app:layout_constraintEnd_toStartOf="@id/btn8" app:layout_constraintWidth_percent="0.22" />
        <Button style="@style/CalculatorButtonStyle" android:id="@+id/btn8" android:text="8"
            app:layout_constraintStart_toEndOf="@id/btn7" app:layout_constraintTop_toBottomOf="@id/btnPlusMinus"
            app:layout_constraintEnd_toStartOf="@id/btn9" app:layout_constraintWidth_percent="0.22" />
        <Button style="@style/CalculatorButtonStyle" android:id="@+id/btn9" android:text="9"
            app:layout_constraintStart_toEndOf="@id/btn8" app:layout_constraintTop_toBottomOf="@id/btnPercent"
            app:layout_constraintEnd_toStartOf="@id/btnMul" app:layout_constraintWidth_percent="0.22" />
        <Button style="@style/CalculatorButtonStyle.Operator" android:id="@+id/btnMul" android:text="×"
            app:layout_constraintStart_toEndOf="@id/btn9" app:layout_constraintTop_toBottomOf="@id/btnDiv"
            app:layout_constraintEnd_toEndOf="parent" app:layout_constraintWidth_percent="0.22" />

        <!-- Row 3 -->
        <Button style="@style/CalculatorButtonStyle" android:id="@+id/btn4" android:text="4"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/btn7"
            app:layout_constraintEnd_toStartOf="@id/btn5" app:layout_constraintWidth_percent="0.22" />
        <Button style="@style/CalculatorButtonStyle" android:id="@+id/btn5" android:text="5"
            app:layout_constraintStart_toEndOf="@id/btn4" app:layout_constraintTop_toBottomOf="@id/btn8"
            app:layout_constraintEnd_toStartOf="@id/btn6" app:layout_constraintWidth_percent="0.22" />
        <Button style="@style/CalculatorButtonStyle" android:id="@+id/btn6" android:text="6"
            app:layout_constraintStart_toEndOf="@id/btn5" app:layout_constraintTop_toBottomOf="@id/btn9"
            app:layout_constraintEnd_toStartOf="@id/btnSub" app:layout_constraintWidth_percent="0.22" />
        <Button style="@style/CalculatorButtonStyle.Operator" android:id="@+id/btnSub" android:text="−"
            app:layout_constraintStart_toEndOf="@id/btn6" app:layout_constraintTop_toBottomOf="@id/btnMul"
            app:layout_constraintEnd_toEndOf="parent" app:layout_constraintWidth_percent="0.22" />

        <!-- Row 4 -->
        <Button style="@style/CalculatorButtonStyle" android:id="@+id/btn1" android:text="1"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/btn4"
            app:layout_constraintEnd_toStartOf="@id/btn2" app:layout_constraintWidth_percent="0.22" />
        <Button style="@style/CalculatorButtonStyle" android:id="@+id/btn2" android:text="2"
            app:layout_constraintStart_toEndOf="@id/btn1" app:layout_constraintTop_toBottomOf="@id/btn5"
            app:layout_constraintEnd_toStartOf="@id/btn3" app:layout_constraintWidth_percent="0.22" />
        <Button style="@style/CalculatorButtonStyle" android:id="@+id/btn3" android:text="3"
            app:layout_constraintStart_toEndOf="@id/btn2" app:layout_constraintTop_toBottomOf="@id/btn6"
            app:layout_constraintEnd_toStartOf="@id/btnAdd" app:layout_constraintWidth_percent="0.22" />
        <Button style="@style/CalculatorButtonStyle.Operator" android:id="@+id/btnAdd" android:text="+"
            app:layout_constraintStart_toEndOf="@id/btn3" app:layout_constraintTop_toBottomOf="@id/btnSub"
            app:layout_constraintEnd_toEndOf="parent" app:layout_constraintWidth_percent="0.22" />

        <!-- Row 5 -->
        <Button style="@style/CalculatorButtonStyle" android:id="@+id/btnBackspace" android:text="⌫"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/btn1"
            app:layout_constraintEnd_toStartOf="@id/btn0" app:layout_constraintWidth_percent="0.22" />
        <Button style="@style/CalculatorButtonStyle" android:id="@+id/btn0" android:text="0"
            app:layout_constraintStart_toEndOf="@id/btnBackspace" app:layout_constraintTop_toBottomOf="@id/btn2"
            app:layout_constraintEnd_toStartOf="@id/btnDot" app:layout_constraintWidth_percent="0.22" />
        <Button style="@style/CalculatorButtonStyle" android:id="@+id/btnDot" android:text="."
            app:layout_constraintStart_toEndOf="@id/btn0" app:layout_constraintTop_toBottomOf="@id/btn2"
            app:layout_constraintEnd_toStartOf="@id/btnEquals" app:layout_constraintWidth_percent="0.22" />
        <Button style="@style/CalculatorButtonStyle.Operator" android:id="@+id/btnEquals" android:text="="
            app:layout_constraintStart_toEndOf="@id/btnDot" app:layout_constraintTop_toBottomOf="@id/btn3"
            app:layout_constraintEnd_toEndOf="parent" app:layout_constraintWidth_percent="0.22" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
