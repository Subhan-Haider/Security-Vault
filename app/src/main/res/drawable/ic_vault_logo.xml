<?xml version="1.0" encoding="utf-8"?>
<!--
    Vault Shield Logo
    Premium cybersecurity / encrypted vault identity mark.
    Used on: Private Browser home screen, splash branding, headers.
    
    Design: Geometric shield silhouette with an inner safe dial/keyhole,
    communicating security, encryption, and trust — without appearing suspicious.
    Fill uses @color/primary to automatically adapt to light and dark themes.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!--
        Shield outer shape:
        A clean, geometric shield that converges to a rounded bottom point.
        Balanced, symmetric, minimal.
    -->
    <path
        android:fillColor="@color/primary"
        android:pathData="
            M12,2
            L3,6
            L3,12
            Q3,17.5 12,22
            Q21,17.5 21,12
            L21,6
            Z
        " />

    <!--
        Inner safe dial ring + keyhole:
        A concentric circle inside the shield suggests a vault lock/safe dial.
        This is rendered as a cutout (using white/transparent inner fill)
        to create a modern, layered icon effect.
    -->
    <!-- Outer ring of safe dial (slightly lighter than shield) -->
    <path
        android:fillColor="#22FFFFFF"
        android:pathData="M12,8 a4,4 0,1,0 0.001,0 Z" />

    <!-- Inner circle of safe dial (darker, creates ring depth) -->
    <path
        android:fillColor="#33000000"
        android:pathData="M12,9 a3,3 0,1,0 0.001,0 Z" />

    <!-- Keyhole vertical slot -->
    <path
        android:fillColor="#44000000"
        android:pathData="M11.5,10.5 L12.5,10.5 L13,14 L11,14 Z" />

    <!-- Three notch ticks on safe dial ring (9, 12, 3 o'clock) -->
    <path
        android:fillColor="#55FFFFFF"
        android:pathData="M12,8 L12,9" />
    <path
        android:fillColor="#55FFFFFF"
        android:pathData="M8,12 L9,12" />
    <path
        android:fillColor="#55FFFFFF"
        android:pathData="M16,12 L15,12" />

</vector>
