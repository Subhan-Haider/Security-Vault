<?xml version="1.0" encoding="utf-8"?>
<!--
    Notification / Status Bar Icon
    Must be flat white (all-white single color), Android requires this
    for notification icons so the OS can tint them appropriately.
    
    Design: Minimal shield silhouette only, no inner detail.
    24x24dp standard notification icon size.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Shield outline only (flat white for notification bar) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M12,2
            L3,6
            L3,12
            Q3,17.5 12,22
            Q21,17.5 21,12
            L21,6
            Z
        " />

    <!-- Dial ring cutout (dark, creates visual interest in notification shade) -->
    <path
        android:fillColor="#55000000"
        android:pathData="M12,8.5 a3.5,3.5 0,1,0 0.001,0 Z" />

    <!-- Inner highlight dot -->
    <path
        android:fillColor="#33FFFFFF"
        android:pathData="M12,9.5 a2.5,2.5 0,1,0 0.001,0 Z" />

</vector>
